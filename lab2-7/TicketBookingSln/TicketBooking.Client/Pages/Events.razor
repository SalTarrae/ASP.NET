@page "/events"
@using System.Net
@using System.Net.Http.Json
@using TicketBooking.Client.Models
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<AuthGuard>
    <h3>Events</h3>

    @if (!string.IsNullOrWhiteSpace(success)) {
        <div class="alert alert-success">@success</div>
    }
    @if (!string.IsNullOrWhiteSpace(error)) {
        <div class="alert alert-danger">@error</div>
    }

    @if (events is null) {
        <p><em>Loading...</em></p>
    } else {
        <div class="row">
            <div class="col-12 col-lg-7">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Date</th>
                            <th class="text-end">Price</th>
                            <th class="text-center">Bookings</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in events) {
                            <tr class="@(editingId == e.EventId ? "table-warning" : "")">
                                <td>@e.Title</td>
                                <td>@e.Location</td>
                                <td>@e.StartDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">@e.BaseTicketPrice</td>
                                <td class="text-center">@e.BookingsCount</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-secondary me-2"
                                            @onclick='() => Nav.NavigateTo($"/events/{e.EventId}")'>
                                        Details
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary me-2"
                                            @onclick="() => StartEdit(e.EventId)">
                                        Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DeleteEvent(e.EventId)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@FormTitle</h5>

                        <EditForm Model="form" OnValidSubmit="SubmitForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="mb-2">
                                <label class="form-label">Title</label>
                                <InputText class="form-control" @bind-Value="form.Title" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" @bind-Value="form.Description" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Location</label>
                                <InputText class="form-control" @bind-Value="form.Location" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="form.StartDate" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Base Ticket Price</label>
                                <InputNumber class="form-control" @bind-Value="form.BaseTicketPrice" />
                            </div>

                            <button class="btn btn-primary" type="submit">@SubmitButtonText</button>
                            <button class="btn btn-secondary ms-2" type="button" @onclick="ResetForm">Cancel</button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
</AuthGuard>

@code {
    private List<EventDto>? events;

    private string? success;
    private string? error;

    private long? editingId = null; // null => Create, not null => Edit
    private EventCreateUpdateDto form = NewForm();

    private string FormTitle => editingId is null ? "Create Event" : $"Edit Event (ID: {editingId})";
    private string SubmitButtonText => editingId is null ? "Create" : "Save";

    protected override async Task OnInitializedAsync() {
        await Reload();
    }

    private static EventCreateUpdateDto NewForm()
        => new() { StartDate = DateTime.Now.AddDays(1), BaseTicketPrice = 1 };

    private void SetMessage(string? ok = null, string? err = null) {
        success = ok;
        error = err;
    }

    private async Task Reload() {
        SetMessage(null, null);

        var resp = await Http.GetAsync("api/events");
        if (resp.StatusCode == HttpStatusCode.Unauthorized) {
            Nav.NavigateTo("/login");
            return;
        }

        if (!resp.IsSuccessStatusCode) {
            SetMessage(null, $"Load failed: {resp.StatusCode}");
            return;
        }

        events = await resp.Content.ReadFromJsonAsync<List<EventDto>>();
    }

    private void StartEdit(long id) {
        SetMessage(null, null);

        var e = events?.FirstOrDefault(x => x.EventId == id);
        if (e == null)
            return;

        editingId = id;

        form = new EventCreateUpdateDto {
            Title = e.Title,
            Description = e.Description,
            Location = e.Location,
            StartDate = e.StartDate,
            BaseTicketPrice = e.BaseTicketPrice
        };
    }

    private void ResetForm() {
        editingId = null;
        form = NewForm();
        SetMessage(null, null);
    }

    private async Task SubmitForm() {
        SetMessage(null, null);

        HttpResponseMessage resp;

        if (editingId is null) {
            resp = await Http.PostAsJsonAsync("api/events", form);
        } else {
            resp = await Http.PutAsJsonAsync($"api/events/{editingId}", form);
        }

        if (resp.StatusCode == HttpStatusCode.Unauthorized) {
            Nav.NavigateTo("/login");
            return;
        }

        if (!resp.IsSuccessStatusCode) {
            SetMessage(null, $"Save failed: {resp.StatusCode}");
            return;
        }

        SetMessage(editingId is null ? "Event created" : "Event updated", null);

        ResetForm();
        await Reload();
    }

    private async Task DeleteEvent(long id) {
        if (!await Confirm($"Delete event #{id}?"))
            return;

        SetMessage(null, null);

        var resp = await Http.DeleteAsync($"api/events/{id}");

        if (resp.StatusCode == HttpStatusCode.Unauthorized) {
            Nav.NavigateTo("/login");
            return;
        }

        if (!resp.IsSuccessStatusCode) {
            SetMessage(null, $"Delete failed: {resp.StatusCode}");
            return;
        }

        SetMessage("Event deleted", null);

        if (editingId == id)
            ResetForm();
        await Reload();
    }

    private async Task<bool> Confirm(string message)
        => await JS.InvokeAsync<bool>("confirm", message);
}