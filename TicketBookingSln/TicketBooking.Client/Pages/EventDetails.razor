@page "/events/{id:long}"
@using System.Net
@using System.Net.Http.Json
@using TicketBooking.Client.Models
@inject HttpClient Http
@inject NavigationManager Nav

<AuthGuard>
    <h3>Event Details</h3>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (model is null && error is null)
    {
        <p><em>Loading...</em></p>
    }
    else if (model is not null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@model.Title</h5>
                <p class="card-text">@model.Description</p>

                <dl class="row mb-0">
                    <dt class="col-sm-3">Location</dt>
                    <dd class="col-sm-9">@model.Location</dd>

                    <dt class="col-sm-3">Start</dt>
                    <dd class="col-sm-9">@model.StartDate.ToString("yyyy-MM-dd HH:mm")</dd>

                    <dt class="col-sm-3">Price</dt>
                    <dd class="col-sm-9">@model.BaseTicketPrice</dd>

                    <dt class="col-sm-3">Bookings</dt>
                    <dd class="col-sm-9">@model.BookingsCount</dd>
                </dl>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/events")'>Back</button>
        </div>
    }
</AuthGuard>

    @code {
    [Parameter] public long id { get; set; }

    private EventDto? model;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        error = null;
        model = null;

        var resp = await Http.GetAsync($"api/events/{id}");
        if (resp.StatusCode == HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("/login");
            return;
        }

        if (resp.StatusCode == HttpStatusCode.NotFound)
        {
            Nav.NavigateTo("/not-found");
            return;
        }

        if (!resp.IsSuccessStatusCode)
        {
            error = $"Load failed: {resp.StatusCode}";
            return;
        }

        model = await resp.Content.ReadFromJsonAsync<EventDto>();
    }
}