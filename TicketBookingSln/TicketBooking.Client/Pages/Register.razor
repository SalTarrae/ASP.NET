@page "/register"
@using System.ComponentModel.DataAnnotations
@inject TicketBooking.Client.Services.AuthService Auth
@inject NavigationManager Nav

<h3>Register</h3>

@if (!string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success">@success</div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<EditForm Model="model" OnValidSubmit="DoRegister">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-2">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="model.Email" />
    </div>

    <div class="mb-2">
        <label>Password</label>
        <InputText class="form-control" type="password" @bind-Value="model.Password" />
    </div>

    <div class="mb-3">
        <label>Confirm password</label>
        <InputText class="form-control" type="password" @bind-Value="model.ConfirmPassword" />
    </div>

    <button class="btn btn-primary" type="submit">Create account</button>
    <button class="btn btn-link" type="button" @onclick='() => Nav.NavigateTo("/login")'>Already have an account?</button>
</EditForm>

@code {
    private string? error;
    private string? success;

    private RegisterForm model = new();

    private class RegisterForm
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "";

        [Required, MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = "";

        [Required]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }

    private async Task DoRegister()
    {
        error = null;
        success = null;

        var (ok, err) = await Auth.RegisterAsync(model.Email, model.Password, model.ConfirmPassword);
        if (!ok)
        {
            error = string.IsNullOrWhiteSpace(err) ? "Registration failed" : err;
            return;
        }

        success = "Registration successful. You can now log in.";
        Nav.NavigateTo("/login");
    }
}